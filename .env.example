# Optional override file.
# server.mjs will first try:
# 1. project .env
# 2. local Codex config/auth
# 3. process environment variables

PORT=3000
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
SERVE_STATIC=true
